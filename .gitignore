# ══════════════════════════════════════════════════════════════
# FlashCook — .gitignore
# Mitigação de riscos de vazamento desde o dia zero
# ══════════════════════════════════════════════════════════════

# ── Dependências ───────────────────────────────────────────────
node_modules/

# ── Variáveis de Ambiente (NUNCA commitar!) ────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
!.env.example

# ── Build outputs ──────────────────────────────────────────────
dist/
build/
.output/
.nuxt/
.next/

# ── Logs ───────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Runtime & Cache ────────────────────────────────────────────
.cache/
.temp/
*.pid
*.seed

# ── Testes & Cobertura ─────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── IDE & Editores ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ── OS Artefactos ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Chaves Privadas & Certificados ────────────────────────────
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ── Docker (futuro) ───────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── Misc ───────────────────────────────────────────────────────
*.tsbuildinfo
.eslintcache
.turbo/
