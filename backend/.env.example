# ══════════════════════════════════════════════════════════════
# FlashCook — BACKEND .env.example
#
# 🔐  VARIÁVEIS SECRETAS — NUNCA commitar o .env real!
# Copie para .env e preencha com os valores do seu projeto.
#
# ATENÇÃO: SERVICE_ROLE_KEY contorna o RLS do Supabase.
# Mantenha-a EXCLUSIVAMENTE no backend. Uma fuga desta chave
# dá acesso irrestrito à totalidade da base de dados.
# ══════════════════════════════════════════════════════════════

# ── Servidor ───────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Supabase (SECRETAS — backend only) ────────────────────────
# URL do projeto (mesmo que o frontend, mas gerida aqui centralmente)
SUPABASE_URL=https://your-project-ref.supabase.co

# ⚠️  SERVICE_ROLE bypassa RLS — NUNCA expor ao frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq AI (SECRETA — nunca expor ao frontend!) ───────────────
GROQ_API_KEY=your-groq-api-key-here

# ── CORS ───────────────────────────────────────────────────────
# Em produção: trocar pelo URL real do frontend
CORS_ORIGIN=http://localhost:5173
